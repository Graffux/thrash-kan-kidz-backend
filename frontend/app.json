{
  "expo": {
    "name": "Thrash Kan Kidz",
    "slug": "thrash-kan-kidz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/tkk-logo.jpg",
    "scheme": "thrashkankidz",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "updates": {
      "enabled": false
    },
    "runtimeVersion": "1.0.0",
    "description": "Collect thrash metal trading cards! Earn coins, complete goals, unlock rare and epic cards. Trade with friends and build the ultimate collection!",
    "githubUrl": "https://github.com/thrashkankidz",
    "primaryColor": "#8B0000",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thrashkankidz.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Share your card collection with photos",
        "NSPhotoLibraryUsageDescription": "Save and share your card collection"
      }
    },
    "android": {
      "package": "com.thrashkankidz.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/tkk-logo.jpg",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/tkk-logo.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/tkk-logo.jpg",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://thrash-kan-kidz-card-col-1-pjuqh6f1.stage-preview.emergentagent.com"
      },
      "eas": {
        "projectId": "thrash-kan-kidz"
      }
    }
  }
}
